# ================================================================
# PM2000 Backend Configuration
# ================================================================
# เลือก MODE ที่ต้องการ:
#   MODE 1 (Direct): ใส่ API Keys ด้านล่าง (สำหรับคนที่มี Key เอง)
#   MODE 2 (Proxy):  ใส่แค่ PROXY_URL + PROXY_APP_KEY (สำหรับเพื่อน)
# ================================================================

# --- MODE 1: Direct API Keys (ไม่ต้องใส่ถ้าใช้ Proxy) ---
MISTRAL_API_KEY=
MISTRAL_AGENT_ID=
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen3.5-plus
DASHSCOPE_FALLBACK_MODEL=qwen-max
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_USER_ID=

# --- MODE 2: Proxy Mode (ไม่ต้องใส่ถ้ามี Key เอง) ---
PROXY_URL=
PROXY_APP_KEY=

# --- Modbus / PM2230 Settings ---
# PM2230_PORT=COM19
# PM2230_BAUDRATE=9600
# PM2230_SLAVE_ID=1
# PM2230_PARITY=E

# --- Rust Core Module ---
# Rust module (pm2000_core) ต้อง build ก่อนถึงจะใช้ได้ (cargo build --release ใน pm2000_core/)
# ตั้งเป็น 1 = ปิด Rust ใช้ Python fallback (default สำหรับ dev)
# ตั้งเป็น 0 = เปิด Rust (ต้อง build แล้วเท่านั้น)
PM2230_NO_RUST=0